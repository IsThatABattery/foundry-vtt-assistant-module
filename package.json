{
  "name": "foundry-vtt-assistant-module",
  "version": "0.1.0",
  "description": "Foundry VTT module for the local Foundry DM assistant MCP bridge.",
  "type": "module",
  "private": false,
  "scripts": {
    "test": "vitest run",
    "build": "tsc -p tsconfig.json && esbuild src/foundry-module.ts --bundle --format=esm --target=es2022 --outfile=dist/foundry-vtt-assistant.js",
    "clean": "rm -rf dist package module.zip",
    "package": "npm run build && node scripts/package-module.mjs",
    "release:manifest": "node scripts/prepare-release-manifest.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "esbuild": "^0.25.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "yazl": "^3.3.1"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IsThatABattery/foundry-vtt-assistant-module.git"
  },
  "bugs": {
    "url": "https://github.com/IsThatABattery/foundry-vtt-assistant-module/issues"
  },
  "homepage": "https://github.com/IsThatABattery/foundry-vtt-assistant-module#readme",
  "keywords": [
    "foundryvtt",
    "foundry-vtt",
    "module",
    "mcp",
    "dm-assistant"
  ]
}
